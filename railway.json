{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildContext": ".",
    "watchPatterns": [
      "Dockerfile",
      "ssh-user-config.sh",
      "claude-settings.json",
      "cl"
    ]
  },
  "deploy": {
    "startCommand": "/usr/local/bin/ssh-user-config.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckTimeout": 150,
    "sleepApplicationStop": true,
    "multiRegion": false
  }
}
